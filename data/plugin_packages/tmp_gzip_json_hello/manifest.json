{
  "plugin_id": "gzip-json-hello",
  "name": "Gzip JSON Hello",
  "version": "1.0.0",
  "description": "返回 gzip 压缩 hello world JSON 的示例插件",
  "templates": [
    {
      "id": "json_hello_world",
      "name": "JSON Hello World",
      "description": "命中后直接返回 gzip 压缩的 JSON hello world",
      "layer": "l7",
      "action": "respond",
      "pattern": "(?i)hello-json|json-hello|hello-world",
      "severity": "high",
      "response_template": {
        "status_code": 200,
        "content_type": "application/json; charset=utf-8",
        "body_source": "file",
        "gzip": true,
        "body_text": "",
        "body_file_path": "hello-world.json",
        "headers": [
          {
            "key": "cache-control",
            "value": "no-store"
          },
          {
            "key": "x-plugin-demo",
            "value": "gzip-json-hello"
          }
        ]
      }
    }
  ]
}